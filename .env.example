# CareerForge - API Configuration Template
# Copy this file to '.env' and fill in your actual keys.
# DO NOT commit your actual '.env' file to version control.

# Google Gemini API Key (Deep Analysis)
GEMINI_API_KEY=your_gemini_key_here

# Deepgram API Key (High-Accuracy Transcription)
DEEPGRAM_API_KEY=your_deepgram_key_here

# MongoDB Connection String
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=your_mongodb_uri_here

# Backend Port
PORT=3000
